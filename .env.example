# Copy to `.env` at the repo root and uncomment lines you want to override.
# All variables are prefixed `MUSICSORT_`. Anything omitted falls back to the
# defaults in api/src/musicsort/config.py.

# ---------- Library layout ----------
# LIBRARY_ROOT is the master knob — songs_dir, quarantine_dir, and
# fingerprint_db_path all default to subdirectories of it. Override just
# LIBRARY_ROOT and the rest follow. Each can be overridden independently
# below if you want a non-standard layout.
#
# MUSICSORT_LIBRARY_ROOT=/Users/robertcalise/Music/Library

# ---------- AutoImport (independent) ----------
# Watcher input. Conventionally a sibling of LIBRARY_ROOT so drops don't
# pollute the library tree.
#
# MUSICSORT_AUTOIMPORT_FOLDER=/Users/robertcalise/Music/AutoImport

# ---------- Library subdirectories (override only for non-default layout) ----------
# These default to subdirs of LIBRARY_ROOT. Setting them explicitly disables
# the derive-from-root behavior for that path.
#
# MUSICSORT_SONGS_DIR=/Users/robertcalise/Music/Library/Songs
# MUSICSORT_QUARANTINE_DIR=/Users/robertcalise/Music/Library/_Unsorted
# MUSICSORT_FINGERPRINT_DB_PATH=/Users/robertcalise/Music/Library/.musicsort/fingerprints.db

# ---------- Dedup ----------
# Chromaprint similarity above this threshold counts as "same recording".
# MUSICSORT_SIMILARITY_THRESHOLD=0.95

# ---------- Watcher ----------
# Seconds of no events on a path before the watcher processes it.
# Large file copies need a few seconds; default is 2.0.
# MUSICSORT_WATCH_SETTLE_SECONDS=2.0
# How often (seconds) the watcher loop wakes up to check for settled files.
# MUSICSORT_WATCH_POLL_SECONDS=0.5
